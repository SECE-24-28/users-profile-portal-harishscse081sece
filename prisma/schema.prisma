// Prisma schema file - defines database structure
// Run `npm run db:push` to apply this schema to your PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - used for login/authentication
model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String // stored as bcrypt hash
}

// Student model - holds all student profile data
model Student {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  department   String
  academicYear Int
  profilePic   String?  // optional URL or path to profile picture
  createdAt    DateTime @default(now())
}
